def auxVerificarCamposVacios(datos: dict) -> bool:
    """
    funcionalidad: Recorre los valores de un diccionario para comprobar si alguno 
                   de sus campos requeridos se encuentra vacío o solo tiene espacios.
    entradas: datos (diccionario)
    salidas: estanCompletos (bool)
    """
    for llave, valor in datos.items():
        if str(valor).strip() == "":
            return False
    return True

def insertarDonadorPrincipal(datosCompletos: dict) -> str:
    """
    funcionalidad: Recibe los datos limpios y estructurados, determina de forma natural 
                   los centros de donación y retorna la bitácora impresa de éxito.
    entradas: datosCompletos (diccionario)
    salidas: bitacoraFicha (string)
    """
    cedula = datosCompletos["cedula"]
    
    # 1. Determinación de Provincias y Hospitales asociados
    codProvincia = cedula[0]
    provinciaNacimiento = registrarCedulaLogica(cedula)
    lugaresDisponibles = ", ".join(lugaresDonacion.get(codProvincia, ["Ninguno"]))
    
#Se guarda al donante en el diccionario global
    baseDonantes[cedula] = {
        "nombre": datosCompletos["nombre"],
        "fechaNacimiento": datosCompletos["fechaNacimiento"],
        "peso": datosCompletos["peso"],
        "tipoSangre": "" # Queda vacío; se llenará en el siguiente paso
    }

    # Ejecución interna para recopilar los mensajes específicos generados previamente
    _, msgEdad = llamadaValidarFecha(datosCompletos["fechaNacimiento"])
    
    # Construcción final de la bitácora impresa
    salidaInformacion = (
        f"\n=========================================\n"
        f"        --- INSERCIÓN EXITOSA ---\n"
        f"=========================================\n"
        f"1. Edad: {msgEdad}\n"
        f"2. Lugar de nacimiento: Dado que usted nació en la provincia de: {provinciaNacimiento}, "
        f"usted podría donar en: {lugaresDisponibles}\n"
        f"3. Datos Registrados de forma natural: {datosCompletos}\n"
    )
    return salidaInformacion

def llamadaProcesarFormularioRegistro(diccionario) -> str:
    """
    funcionalidad: Ejecuta la validación secuencial en cadena de todos los componentes 
                   del formulario de datos y procesa la inserción en caso exitoso de forma natural.
    entradas: diccionario (diccionario)
    salidas: mensajeResultado (string)
    """
    # 1. Comprobación de nulos o vacíos
    if not auxVerificarCamposVacios(diccionario):
        return "Error: Todos los campos del formulario son requeridos."
    
    # 2. Control de flujos llamando individualmente a cada sub-interfaz de validación
    validacionCed, resultadoCed = llamarRegistrarCedulaLogica(diccionario["cedula"])
    if not validacionCed: 
        return f"Error en Cédula: {resultadoCed}"
    
    validacionFecha, resultadoFecha = llamadaValidarFecha(diccionario["fecha_nacimiento"])
    if not validacionFecha: 
        return f"Error en Fecha: {resultadoFecha}"

#  Validar el peso antes de hacer la inserción basica
    validacionPeso, resultadoPeso = llamarEvaluarPesoDonacion(diccionario["peso"])
    if not validacionPeso:
        return f"Error en Peso: {resultadoPeso}"
    
    # 3. Consolidar de manera natural la estructura limpia de datos (Diccionario de Retorno)
    datosLimpios = {
        "cedula": diccionario["cedula"],
        "nombre": diccionario["nombre"],
        "fechaNacimiento": diccionario["fecha_nacimiento"],
        "peso": float(diccionario["peso"])
    }
    
    reporteInsercion = insertarDonadorPrincipal(datosLimpios)
    print(reporteInsercion)
    
    cedulaDonante = datosLimpios["cedula"]
    
    # Activamos la función de llamada de la sangre pasándole el donante creado
    sangreExitosa = llamarRegistrarTipoSangre(cedulaDonante, baseDonantes)
    
    if sangreExitosa:
        return f"\n[ÉXITO TOTAL]: Registro completado. Ficha en sistema: {baseDonantes[cedulaDonante]}"
    else:
        # Si el usuario digita mal la opción de sangre, borramos la ficha incompleta por integridad
        del baseDonantes[cedulaDonante]
        return "Error: El registro fue cancelado debido a una selección de sangre inválida."

    return insertarDonadorPrincipal(datosLimpios)
