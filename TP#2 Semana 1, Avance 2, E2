def auxValidarOpcionSangre(entrada):
    """
    Funcionalidad: Valida si la string ingresada corresponde a un digito entre 1 y 8.
    Entradas:
    - entrada (str)
    Salidas:
    - resultado (bool)
    """
    if entrada.isdigit():
        opcion = int(entrada)
        if 1 <= opcion <= 8:
            return True
    return False

def registrarTipoSangre(opcionValida, donanteId, estructuraDonantes):
    """
    Funcionalidad: Almacena el tipo de sangre en el expediente del donante y retorna la recomendacion.
    Entradas:
    - opcionValida (int)
    - donanteId (str)
    - estructuraDonantes (dict)
    Salidas:
    - recomendacion (str)
    """
    datosSangre = infoSangre[opcionValida]
    tipoAsignado = datosSangre["tipo"]

    estructuraDonantes[donanteId]["tipoSangre"] = tipoAsignado
    return datosSangre["info"]

