import re
from datetime import datetime

lugaresDonacion = {
    "1": ["Banco Nacional de Sangre", "Hospital México", "Hospital San Juan de Dios"],  # San José
    "2": ["Hospital San Rafael de Alajuela", "Hospital de San Ramón", "Hospital del Cantón Norteño"],  # Alajuela
    "3": ["Hospital Max Peralta"],  # Cartago
    "4": ["Hospital San Vicente de Paúl"],  # Heredia
    "5": ["Hospital La Anexión en Nicoya", "Hospital Enrique Baltodano de Liberia"],  # Guanacaste
    "6": ["Hospital Monseñor Sanabria"],  # Puntarenas
    "7": ["Hospital Tony Facio", "Hospital de Guápiles"],  # Limón
    "8": ["Banco Nacional de Sangre", "Hospital México", "Hospital San Juan de Dios"]  # Naturalizados (donan en SJ)
}

def auxValidarCedula(cedula: str) -> bool:
    """
    funcionalidad: Valida si la cédula ingresada cumple con el formato requerido 
                   mediante expresiones regulares, verificando que no empiece con 0.
    entradas: cedula (string)
    salidas: resultado (bool)
    """
    if not isinstance(cedula, str):
        return False
    patron = r"^[1-9]-\d{4}-\d{4}$"
    return bool(re.match(patron, cedula))

def registrarCedulaLogica(cedula: str) -> str:
    """
    funcionalidad: Procesa el primer dígito de la cédula para determinar y retornar 
                   el nombre de la provincia de origen correspondiente.
    entradas: cedula (string)
    salidas: provincia (string)
    """
    provinciaId = cedula[0]
    provincias = {
        "1": "San José", "2": "Alajuela", "3": "Cartago", "4": "Heredia",
        "5": "Guanacaste", "6": "Puntarenas", "7": "Limón", "8": "Naturalizado"
    }
    return provincias.get(provinciaId, "Desconocida")

def llamadaValidarCedula(entradaCedulaWidget) -> tuple:
    """
    funcionalidad: Recupera el texto de la cédula (sea de un objeto widget o texto plano) 
                   y coordina el flujo de validación y obtención de provincia.
    entradas: entradaCedulaWidget (objeto widget o string)
    salidas: resultadoValidacion (tupla conteniendo un bool y un string con la provincia o error)
    """
    cedulaTexto = entradaCedulaWidget.get() if hasattr(entradaCedulaWidget, 'get') else entradaCedulaWidget
    
    if auxValidarCedula(cedulaTexto):
        provincia = registrarCedulaLogica(cedulaTexto)
        return True, provincia
    else:
        return False, "Formato de cédula inválido. Debe ser #-####-#### solo números enteros."

def auxValidarFecha(fecha: str) -> bool:
    """
    funcionalidad: Valida mediante expresiones regulares que la fecha tenga el formato 
                   DD/MM/AAAA y comprueba con datetime que sea una fecha real en el calendario.
    entradas: fecha (string)
    salidas: esValida (bool)
    """
    patron = r"^\d{2}/\d{2}/\d{4}$"
    if not re.match(patron, fecha):
        return False
    try:
        datetime.strptime(fecha, "%d/%m/%Y")
        return True
    except ValueError:
        return False

def evaluarMayoriaEdad(fechaStr: str) -> bool:
    """
    funcionalidad: Calculates with precision the exact age of the target person by 
                   comparing the current date with the birthdate to verify legal age (>= 18 years).
    entradas: fechaStr (string)
    salidas: esMayor (bool)
    """
    fechaNac = datetime.strptime(fechaStr, "%d/%m/%Y")
    hoy = datetime.now()
    
    # Cálculo exacto restando un año si el mes/día actual es menor al de nacimiento
    edad = hoy.year - fechaNac.year - ((hoy.month, hoy.day) < (fechaNac.month, fechaNac.day))
    return edad >= 18

def llamadaValidarFecha(fechaTabla) -> tuple:
    """
    funcionalidad: Extrae el texto del control gráfico de fecha, comprueba su validez 
                   temporal y dictamina si es elegible o no para donar por criterio de edad.
    entradas: fechaTabla (objeto widget o string)
    salidas: resultadoEdad (tupla conteniendo un bool y un string con el veredicto o error)
    """
    fechaTexto = fechaTabla.get() if hasattr(fechaTabla, 'get') else fechaTabla
    
    if not auxValidarFecha(fechaTexto):
        return False, "Formato de fecha inválido o irreal. Debe ser DD/MM/AAAA."
    
    esMayor = evaluarMayoriaEdad(fechaTexto)
    if esMayor:
        return True, "Dado su fecha de nacimiento usted ya puede ser donador."
    else:
        return False, "Dado su fecha de nacimiento usted aún no puede ser donador."


